# Frontend Environment Variables for Production
# Copy this file to .env and fill in your values

# Backend API URL - Update this to your Render backend URL
VITE_API_URL=https://your-backend.onrender.com

# Default: uses localhost if not set
# VITE_API_URL=http://localhost:8000

# Sentry
VITE_SENTRY_DSN="https://f0cdd56f74c2fd4c3572d33c21645ec0@o4511026879594496.ingest.us.sentry.io/4511093846900736"
VITE_SENTRY_TRACES_SAMPLE_RATE=0.2
VITE_SENTRY_REPLAYS_SESSION_SAMPLE_RATE=0.1
VITE_SENTRY_REPLAYS_ON_ERROR_SAMPLE_RATE=1.0

# Optional: shown in Sentry releases
VITE_APP_VERSION=local-dev

# Optional: enable source map upload (build-time only)
# SENTRY_AUTH_TOKEN=
# SENTRY_ORG=
# SENTRY_PROJECT=
